from sqlalchemy import create_engine, inspect, text, Engine
import pandas as pd
from .base import DatabaseConnector

class SQLServerConnector(DatabaseConnector):
    """Microsoft SQL Server database connector implementation."""
    
    def __init__(self, connection_string: str):
        """
        Initialize SQL Server connector.
        
        Args:
            connection_string: SQLAlchemy connection string
        """
        self.connection_string = connection_string
        self.engine = self.get_engine()
    
    def get_engine(self) -> Engine:
        """Create SQL Server engine instance."""
        return create_engine(self.connection_string)
    
    def _get_raw_schema(self, sample_rows: int = 3) -> str:
        """Generate schema description with sample data."""
        inspector = inspect(self.engine)
        schema_info = []
        
        # Get all schemas
        for schema_name in inspector.get_schema_names():
            for table_name in inspector.get_table_names(schema=schema_name):
                # Get column information
                columns = []
                for col in inspector.get_columns(table_name, schema=schema_name):
                    columns.append(f"{col['name']} ({col['type']})")
                
                # Get sample data
                sample_data = ""
                try:
                    with self.engine.connect() as connection:
                        result = connection.execute(
                            text(f"SELECT TOP {sample_rows} * FROM {schema_name}.{table_name}")
                        )
                        sample_data = "\n".join(str(row) for row in result.fetchall())
                except Exception:
                    sample_data = "Unable to fetch sample data"
                
                schema_info.append(
                    f"Schema: {schema_name}\n"
                    f"Table: {table_name}\n"
                    f"Columns: {', '.join(columns)}\n"
                    f"Sample Rows:\n{sample_data}"
                )
        
        return "\n\n".join(schema_info)
    
    def execute_query(self, query: str) -> tuple[pd.DataFrame, str | None]:
        """Execute SQL query safely with error handling."""
        try:
            with self.engine.connect() as connection:
                result = connection.execute(text(query))
                df = pd.DataFrame(result.fetchall(), columns=list(result.keys()))
            return df, None
        except Exception as e:
            return pd.DataFrame(), f"SQL Server Error: {str(e)}"